generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          String         @default("USER")
  phone         String?
  address       String?
  createdAt     DateTime       @default(now())
  vehicles      Vehicle[]
  interventions Intervention[]
  reviews       Review[]
}

model Vehicle {
  id            String         @id @default(cuid())
  userId        String
  make          String
  model         String
  year          Int
  licensePlate  String?
  vin           String?
  user          User           @relation(fields: [userId], references: [id])
  interventions Intervention[]
}

model Annonce {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  category    String   @default("CAR")
  images      String   @default("[]")
  mileage     Int?
  make        String?
  model       String?
  year        Int?
  condition   String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
}

model Intervention {
  id          String   @id @default(cuid())
  userId      String
  vehicleId   String?
  title       String
  description String
  date        DateTime
  mileage     Int?
  price       Float?
  status      String   @default("PENDING")
  notes       String?
  user        User     @relation(fields: [userId], references: [id])
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  authorName  String
  authorEmail String
  userId      String?
  rating      Int
  comment     String
  createdAt   DateTime @default(now())
  approved    Boolean  @default(false)
  user        User?    @relation(fields: [userId], references: [id])
}

model ContactRequest {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  vehicleMake   String
  vehicleModel  String
  vehicleYear   String
  description   String
  preferredDate String?
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
}

// ─── Email automation models ───────────────────────────────────────────────────

model EmailRule {
  id        String   @id @default(cuid())
  name      String
  // Matching criteria (stored as JSON arrays serialised to strings)
  senders   String   @default("[]")   // ["@example.com", "boss@acme.com"]
  subjects  String   @default("[]")   // keywords matched against subject
  keywords  String   @default("[]")   // keywords matched against body
  // Action
  category  String   // CONTACT | INVOICE | REVIEW | SPAM | GENERAL
  imapFolder String  // target IMAP folder, e.g. "Clinikauto/Devis"
  autoReply Boolean  @default(false)
  active    Boolean  @default(true)
  priority  Int      @default(0)      // higher = evaluated first
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id          String   @id @default(cuid())
  messageId   String   @unique           // IMAP Message-ID header
  from        String
  to          String
  subject     String
  receivedAt  DateTime
  category    String   @default("GENERAL")
  imapFolder  String   @default("INBOX")
  status      String   @default("PENDING") // PENDING | PROCESSED | IGNORED | ERROR
  ruleId      String?
  linkedType  String?  // ContactRequest | Intervention | Review
  linkedId    String?
  autoReplied Boolean  @default(false)
  createdAt   DateTime @default(now())
}
