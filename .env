DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="clinikauto-secret-key-2024-very-secure"
NEXTAUTH_URL="http://localhost:3000"

# ─── Mail automation ──────────────────────────────────────────────────────────
# IMAP (incoming mail)
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_SECURE="true"
IMAP_USER="votre-email@gmail.com"
IMAP_PASSWORD="votre-mot-de-passe-application"

# SMTP (outgoing mail / Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="votre-email@gmail.com"
SMTP_PASSWORD="votre-mot-de-passe-application"
SMTP_FROM_NAME="Clinikauto"

# Admin email that receives daily digests and alerts
ADMIN_EMAIL="admin@clinikauto.fr"

# Worker poll interval in minutes (also used by node-cron)
MAIL_POLL_INTERVAL_MIN="5"
